vars: {
  d2-config: {
    theme-id: 8
  }
}

direction: right

title: "Aria вЂ” Secrets Management Flow" {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

eng: Engineer {
  shape: person
}

openssl: openssl rand {
  shape: parallelogram
  label: "openssl rand -hex 32\n(generates 64-char hex string)\nopenssl rand -hex 16\n(generates 32-char hex string)"
}

vault_file: group_vars/all/vault.yml {
  label: "group_vars/all/vault.yml\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвљ  AES-256 encrypted at rest\nвљ  Listed in .gitignore\nвљ  NEVER commit plaintext\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nvault_grafana_admin_password\nvault_semaphore_admin_password\nvault_semaphore_encryption_key\nvault_twingate_network\nvault_twingate_access_token\nvault_twingate_refresh_token\nvault_authelia_jwt_secret\nvault_authelia_session_secret\nvault_authelia_storage_encryption_key\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEncrypt:  ansible-vault encrypt vault.yml\nEdit:     ansible-vault edit vault.yml\nDecrypt:  ansible-vault decrypt vault.yml"
  shape: stored_data
}

vars_file: group_vars/all/vars.yml {
  label: "group_vars/all/vars.yml\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвњ“ Safe to commit\nвњ“ No secrets вЂ” only references\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ngrafana_admin_password:\n  vault_grafana_admin_password\nsemaphore_admin_password:\n  vault_semaphore_admin_password\nsemaphore_encryption_key:\n  vault_semaphore_encryption_key\ntwingate_network:\n  vault_twingate_network\ntwingate_access_token:\n  vault_twingate_access_token\ntwingate_refresh_token:\n  vault_twingate_refresh_token\nauthelia_jwt_secret:\n  vault_authelia_jwt_secret\nauthelia_session_secret:\n  vault_authelia_session_secret\nauthelia_storage_encryption_key:\n  vault_authelia_storage_encryption_key"
  shape: rectangle
}

vault_pass: .vault_pass {
  label: ".vault_pass\n(gitignored В· chmod 600)\nStores vault password\nUsed with:\n  --vault-password-file .vault_pass"
  shape: stored_data
}

ansible_mem: Ansible Runtime (in-memory) {
  label: "Ansible variable scope\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSecrets decrypted in RAM only\nNever written to disk in plaintext\nMerges: vault vars + public vars\nAvailable as variable_name\nin all templates for this run"
  style.stroke-dash: 4
}

templates: Jinja2 Templates {
  label: "roles/services/templates/{stack}/docker-compose.yml.j2\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nContains Jinja2 placeholders:\ngrafana_admin_password\nsemaphore_admin_password\nsemaphore_encryption_key\ntwingate_network\ntwingate_access_token\ntwingate_refresh_token\nauthelia_jwt_secret\nauthelia_session_secret\nauthelia_storage_encryption_key"
}

compose_rendered: Rendered docker-compose.yml {
  label: "/opt/services/{stack}/docker-compose.yml\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nOwned by root В· mode 0644\nPlaintext with injected secrets\nRead by Docker Compose at startup"
  shape: rectangle
}

containers: Running Containers {
  grafana_c: "grafana container\nenv: GF_SECURITY_ADMIN_PASSWORD"
  semaphore_c: "semaphore container\nenv: SEMAPHORE_ADMIN_PASSWORD\nenv: SEMAPHORE_ACCESS_KEY_ENCRYPTION"
  twingate_c: "twingate-connector container\nenv: TWINGATE_NETWORK\nenv: TWINGATE_ACCESS_TOKEN\nenv: TWINGATE_REFRESH_TOKEN"
  authelia_c: "authelia container\nenv: AUTHELIA_JWT_SECRET\nenv: AUTHELIA_SESSION_SECRET\nenv: AUTHELIA_STORAGE_ENCRYPTION_KEY"
}

eng -> openssl: "generate random secrets"
openssl -> vault_file: "paste values"
eng -> vault_file: "fill in passwords\nand TwinGate tokens"
eng -> vault_pass: "set vault password"

vault_pass -> ansible_mem: "--vault-password-file"
vault_file -> ansible_mem: "AES-256 decrypt\n(vault password)"
vars_file -> ansible_mem: "load variable mappings"

ansible_mem -> templates: "render Jinja2\n(secrets substituted)"
templates -> compose_rendered: "write rendered file\nto /opt/services/"
compose_rendered -> containers: "docker compose up\n(env vars injected at runtime)"
